# Database
DATABASE_URL=postgresql+asyncpg://alri:password@db:5432/alri
DB_PASSWORD=password

# Redis
REDIS_URL=redis://redis:6379/0

# Auth (Clerk)
JWT_SECRET=your-secret-key
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# LLM
LLM_PROVIDER=kimi
NVIDIA_NIM_API_KEY=your-nvidia-api-key
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
KIMI_MODEL=moonshotai/kimi-k2-instruct

# OCR (PaddleOCR — runs locally, no API key needed)
# PP-OCRv5 for text extraction, PP-StructureV3 for table detection
# Models auto-download on first run

# Email (Resend)
RESEND_API_KEY=re_xxx
RESEND_FROM_HELLO=hello@alri.health
RESEND_FROM_BILLING=billing@alri.health

# Payments (Paystack — supports Opay/USSD)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=xxx

# WhatsApp
WHATSAPP_TOKEN=xxx
WHATSAPP_VERIFY_TOKEN=xxx
WHATSAPP_PHONE_NUMBER_ID=xxx

# Storage
STORAGE_TYPE=local
STORAGE_PATH=/data/uploads

# App
APP_URL=https://alri.health
CORS_ORIGINS=https://alri.health,http://localhost:3000
