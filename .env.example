# Database
DATABASE_URL=postgresql+asyncpg://alri:password@db:5432/alri
DB_PASSWORD=password

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=change-me
JWT_ALG=HS256
JWT_EXPIRES_MINUTES=43200
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=

# LLM
LLM_PROVIDER=kimi
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
KIMI_MODEL=moonshotai/kimi-k2-instruct

# OCR
GOOGLE_VISION_API_KEY=

# WhatsApp
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Storage
STORAGE_TYPE=local
STORAGE_PATH=/data/uploads

# App
APP_URL=https://alri.health
CORS_ORIGINS=https://alri.health,http://localhost:3000
